rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Role comes from the custom claim set by /api/admin/set-role.
    // Users with no claim (new sign-ups) are treated as 'free'.
    function role() {
      return signedIn() && 'role' in request.auth.token
        ? request.auth.token.role
        : '';
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isFellow() {
      return role() == 'admin' || role() == 'fellow';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isAdmin() || isSelf(uid);
      // Sign-up creates the caller's own profile; role must start as 'free'.
      allow create: if isSelf(uid)
        && request.resource.data.get('role', 'free') == 'free';
      // The role field is read-only from the client — it mirrors the custom
      // claim and only changes via /api/admin/set-role (Admin SDK bypasses
      // these rules). Admin clients may update other fields, e.g. the
      // approvedQuestionCount counter written during question approval.
      // curriculumGated (missing = gated) is admin-only: it controls whether
      // the user's topics unlock sequentially, so users can't open their own.
      allow update: if isAdmin()
        ? !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        : isSelf(uid)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'curriculumGated']);
      allow delete: if false;

      // Per-fellow progress: one doc per topic, owned by the fellow.
      // Admins also write here when signing off Skills objectives.
      // userId/topicId must match the path so collectionGroup queries
      // and admin views can trust the denormalized fields.
      match /progress/{topicId} {
        allow read: if isAdmin() || isSelf(uid);
        allow create, update: if isAdmin()
          || (isFellow() && isSelf(uid)
            && request.resource.data.userId == uid
            && request.resource.data.topicId == topicId);
        allow delete: if isAdmin();
      }
    }

    match /topics/{topicId} {
      allow read: if signedIn();
      // Progress lives in users/{uid}/progress, so topic and objective docs
      // are admin-authored content only.
      allow create, update, delete: if isAdmin();

      match /objectives/{objectiveId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /questions/{questionId} {
      // Fellows only ever query their own questions; admins review everything.
      allow read: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid);
      allow create: if isFellow()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.get('approved', false) == false;
      // Authors may edit their own questions but cannot approve them or
      // reassign authorship; approval is admin-only.
      allow update: if isAdmin()
        || (isFellow()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['approved']));
      allow delete: if isAdmin()
        || (isFellow() && resource.data.authorId == request.auth.uid);
    }

    match /fieldReports/{reportId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid);
      allow create: if isFellow()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAdmin()
        || (isFellow()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId);
      allow delete: if isAdmin()
        || (isFellow() && resource.data.authorId == request.auth.uid);
    }

    match /schedules/{scheduleId} {
      allow read: if signedIn();
      allow create, update, delete: if isFellow();
    }
  }
}
